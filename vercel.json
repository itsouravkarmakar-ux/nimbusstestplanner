{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/src/**",
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ]
}
