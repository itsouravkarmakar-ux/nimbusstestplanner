{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 25
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ],
  "framework": null,
  "outputDirectory": "frontend/dist"
}
